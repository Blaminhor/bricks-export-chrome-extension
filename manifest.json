{
  "manifest_version": 3,
  "name": "BRICKS.co : Export CSV et JSON",
  "version": "1.0.0",
  "description": "Exportez vos investissements Bricks.co en CSV et JSON (AllMyCapital)",
  "permissions": ["activeTab", "downloads"],
  "host_permissions": [
    "https://app.bricks.co/*",
    "https://api.bricks.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://app.bricks.co/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
